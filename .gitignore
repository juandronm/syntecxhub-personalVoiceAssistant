# Add this to your .gitignore file (create if it doesn't exist)
echo ".env" >> .gitignore
echo "**/.env" >> .gitignore
echo "*.env" >> .gitignore

# If you have other environment files
echo ".env.local" >> .gitignore
echo ".env.*.local" >> .gitignore

# Commit the .gitignore changes
git add .gitignore
git commit -m "Add .env to .gitignore"